#!/usr/bin/env bash
# Build and launch the PodcastHacker desktop app for the current platform.
set -euo pipefail
cd "$(dirname "$0")"

case "$(uname -s)" in
    Darwin) PLATFORM=mac ;;
    Linux)  PLATFORM=linux ;;
    *) echo "Unsupported platform: $(uname -s) (expected macOS or Linux)" >&2; exit 1 ;;
esac

./gradlew :desktopApp:createDistributable

APP_DIR="desktopApp/build/compose/binaries/main/app"
# packageName is "PodcastHacker-SNAPSHOT" for snapshot builds, "PodcastHacker" for releases
case "$PLATFORM" in
    mac)
        APP_BUNDLE=$(find "$APP_DIR" -maxdepth 1 -name "PodcastHacker*.app" | head -n 1)
        [ -n "$APP_BUNDLE" ] || { echo "No app bundle found in $APP_DIR" >&2; exit 1; }
        open "$APP_BUNDLE"
        ;;
    linux)
        BINARY=$(find "$APP_DIR" -maxdepth 3 -path "*/bin/PodcastHacker*" -type f | head -n 1)
        [ -n "$BINARY" ] || { echo "No binary found in $APP_DIR" >&2; exit 1; }
        exec "$BINARY"
        ;;
esac
